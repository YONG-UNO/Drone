# Generated by CLion for K&R braces
# The K&R style, also known as Kernighan and Ritchie style, is a common coding style named after the authors of "The C Programming Language."
# In this style, the opening brace is placed on the same line as the control statement, and the closing brace is on its own line.
BasedOnStyle: LLVM

BraceWrapping:
  AfterClass: false
  AfterControlStatement: false
  AfterEnum: false
  AfterFunction: false
  AfterNamespace: false
  AfterStruct: false
  AfterUnion: false
  BeforeCatch: false
  BeforeElse: false
BreakBeforeBraces: Custom

IndentWidth: 4               # 缩进宽度 4 个空格（C/C++ 常用，也可改为 2）
TabWidth: 4                  # Tab 键宽度对应缩进宽度
IndentBraces: false          # 不缩进大括号本身（符合 K&R 风格常规习惯，可选但推荐）